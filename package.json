{
  "name": "chordvault",
  "version": "1.14.0",
  "description": "Self-hosted chord sheet manager with transpose",
  "author": "Rudy Samuel",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/rusahu/chordvault.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"NODE_ENV=development node server.js\" \"cd frontend && npm run dev\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"*.js\" \"lib/**/*.js\" \"routes/**/*.js\"",
    "format:check": "prettier --check \"*.js\" \"lib/**/*.js\" \"routes/**/*.js\"",
    "prepare": "husky || true"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "chordsheetjs": "^15.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "opencc-js": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4"
  },
  "lint-staged": {
    "*.js": "eslint",
    "lib/**/*.js": "eslint",
    "routes/**/*.js": "eslint",
    "frontend/src/**/*.{ts,tsx}": "cd frontend && npx eslint"
  }
}
