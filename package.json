{
  "name": "chordvault",
  "version": "1.0.0",
  "description": "Self-hosted chord sheet manager with transpose",
  "author": "Rudy Samuel",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/rusahu/chordvault.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"cd frontend && npm run dev\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"*.js\" \"lib/**/*.js\" \"routes/**/*.js\"",
    "format:check": "prettier --check \"*.js\" \"lib/**/*.js\" \"routes/**/*.js\"",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "chordsheetjs": "^14.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "patch-package": "^8.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1"
  }
}
